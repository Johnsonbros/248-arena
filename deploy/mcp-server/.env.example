# Copy to .env and fill in. Do NOT commit .env.

# Strong random token (>=16 chars). The connector must send: Authorization: Bearer <this>
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# GitHub read token if Johnsonbros/248-arena is private (fine-grained, contents:read).
GIT_TOKEN=

# Usually leave these as-is:
MCP_PORT=8765
APP_DIR=/mnt/user/appdata/248-arena
REPO_SLUG=Johnsonbros/248-arena
DEFAULT_BRANCH=claude/repo-overview-h1p7ls
CONTAINER_NAME=arena248
ARENA_PORT=8248
